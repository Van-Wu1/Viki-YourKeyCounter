{
  "name": "keycounter-widget",
  "version": "1.0.0",
  "description": "KeyCounter 悬浮框 - Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.keycounter.widget",
    "productName": "KeyCounter Widget",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
