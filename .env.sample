# 复制此文件为 .env 并填写真实配置（.env 已加入 .gitignore，不会提交）

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 本地 API 端口（可选，默认 3000；若与其他应用冲突可改为如 55555）
PORT=55555

# 邮箱验证/重置链接跳转（可选，Supabase 默认使用项目 Site URL）
# SUPABASE_EMAIL_REDIRECT=https://your-domain.com/confirm
