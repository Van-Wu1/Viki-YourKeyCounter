# ===========================================
# KeyCounter 项目 .gitignore
# ===========================================

# ----- 运行时数据（用户本地统计，不应提交） -----
count.ini
gui.ini
health_status.ini
data/*.ini

# ----- Node.js / API -----
api/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
bun.lockb

# ----- Node.js / Electron (widget) -----
widget/node_modules/
widget/dist/
widget/out/
widget/*.exe
widget/*.dmg
widget/*.AppImage
widget/*.msi
widget/*.zip
.electron/

# ----- AHK 脚本 -----
*.ahk~
*.ahk.bak

# ----- 日志与临时文件 -----
keycounter_widget_cmd.txt
keycounter_health_cmd.txt
keycounter_widget_pid.txt
*.log
*.tmp
*.temp
*.bak
*.swp
*~
debug-*.log
.cache/

# ----- 操作系统 -----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ----- 编辑器 / IDE -----
.vscode/
.idea/
.cursor/
.cursor/plans/
*.sublime-project
*.sublime-workspace
agent-transcripts/

# ----- 环境与密钥（若后续添加） -----
.env
.env.local
.env.*.local

# ----- 可选：若打赏二维码为个人收款码，可取消下行注释 -----
# public/moneycome.jpg
