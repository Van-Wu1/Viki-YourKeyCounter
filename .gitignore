# ===========================================
# KeyCounter 项目 .gitignore
# ===========================================

# ----- 运行时数据（用户本地统计，不应提交） -----
count.ini
gui.ini
data/*.ini

# ----- Node.js / Electron (widget) -----
widget/node_modules/
widget/dist/
widget/out/
widget/*.exe
widget/*.dmg
widget/*.AppImage

# ----- 日志与临时文件 -----
keycounter_widget_cmd.txt
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# ----- 操作系统 -----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ----- 编辑器 / IDE -----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ----- 可选：若打赏二维码为个人收款码，可取消下行注释 -----
# public/moneycome.jpg
